<!DOCTYPE html>
<html>
<head>
    <title>Responsive Web Design</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="navbar">
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Services</a>
        <a href="#">Contact</a>
    </div>
    <div class="container">
        <img src="https://via.placeholder.com/600x300"
             alt="Sample Image"
             class="bannerImage">
        <h1>
            Responsive Web Design
        </h1>
        <p>
            This webpage changes layout based on screen size.
        </p>
    </div>
</body>
</html>






//CSS
body {
    margin: 0;
    font-family: Arial;
}
.navbar {
    display: flex;
    justify-content: center;
    background-color: darkblue;
    padding: 2vh;
}
.navbar a {
    color: white;
    text-decoration: none;
    margin: 0 2vw;
    font-size: 1.2rem;
}
.container {
    width: 80%;
    margin: auto;
    text-align: center;
    padding: 5vh;
}
.bannerImage {
    width: 60%;
    height: auto;
}
h1 {
    font-size: 3vw;
}
@media screen and (max-width: 768px) {
    .navbar {
        flex-direction: column;
        align-items: center;
    }
    .navbar a {
        margin: 10px 0;
        font-size: 16px;
    }
    .bannerImage {
        width: 90%;
    }
    h1 {
        font-size: 24px;
    }
}

