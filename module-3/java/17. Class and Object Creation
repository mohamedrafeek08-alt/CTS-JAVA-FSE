import java.util.*;
class Car
{
    String make = "Toyota";
    String model = "Innova";
    int year = 2022;
    void displayDetails()
    {
        System.out.println(make);
        System.out.println(model);
        System.out.println(year);
    }
}
public class ObjectCreation
{
	public static void main(String[] args) {
	    Car c = new Car();
	    c.displayDetails();
	}
}
