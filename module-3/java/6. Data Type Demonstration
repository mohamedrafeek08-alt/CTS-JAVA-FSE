public class DataType
{
	public static void main(String[] args) {
	    int a = 10;
	    float b = 10.0f;
	    double c = 1234567.89;
	    char d = 'a';
	    boolean e = true;
		System.out.println("The Integer is: "+ a);
		System.out.println("The Float is: "+ b);
		System.out.println("The Double is: "+ c);
		System.out.println("The Character is: "+ d);
		System.out.println("The Boolean is: "+ e);
	}
}
