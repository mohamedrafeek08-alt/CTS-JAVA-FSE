import java.util.*;
class Animal
{
    void makeSound()
    {
        System.out.println("Each Animal has Different Sounds..");
    }
}
class Dog extends Animal
{
    void makeSound()
    {
        System.out.println("Bark");
    }
}
public class inheritance
{
	public static void main(String[] args) {
		Animal a = new Animal();
		Dog d = new Dog();
		a.makeSound();
		d.makeSound();
	}
}
