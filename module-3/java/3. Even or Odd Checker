import java.util.*;
public class oddOrEvenChecker
{
	public static void main(String[] args) {
	    Scanner s = new Scanner(System.in);
	    System.out.print("Enter the Number: ");
	    int n = s.nextInt();
	    if(n%2 == 0)
	    {
	        System.out.println("Even");
	    }
	    else
	    {
	        System.out.println("Odd");
	    }
	}
}
