<!DOCTYPE html>
<html>
<head>
    <title>Reorder Columns</title>
    <link rel="stylesheet" href="css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-6 order-md-2 bg-primary text-white p-4">
                Column 1
            </div>
            <div class="col-md-6 order-md-1 bg-success text-white p-4">
                Column 2
            </div>
        </div>
    </div>
    <script src="js/bootstrap.bundle.min.js"></script>
</body>
</html>
