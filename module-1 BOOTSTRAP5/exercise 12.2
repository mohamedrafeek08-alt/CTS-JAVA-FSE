<!DOCTYPE html>
<html>
<head>
    <title>Pricing Section</title>
    <link rel="stylesheet" href="css/bootstrap.min.css">
</head>
<body>
    <div class="container py-5">
        <h2 class="text-center mb-5">
            Pricing Plans
        </h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <h3>
                        Basic
                    </h3>
                    <h4 class="my-3">
                        $10
                    </h4>
                    <p>
                        Basic features for beginners.
                    </p>
                    <button class="btn btn-primary mt-3">
                        Buy Now
                    </button>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <h3>
                        Standard
                    </h3>
                    <h4 class="my-3">
                        $20
                    </h4>
                    <p>
                        Standard features for users.
                    </p>
                    <button class="btn btn-success mt-3">
                        Buy Now
                    </button>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <h3>
                        Premium
                    </h3>
                    <h4 class="my-3">
                        $30
                    </h4>
                    <p>
                        Premium features with support.
                    </p>
                    <button class="btn btn-danger mt-3">
                        Buy Now
                    </button>
                </div>
            </div>
        </div>
    </div>
    <script src="js/bootstrap.bundle.min.js"></script>
</body>
</html>
