<!DOCTYPE html>
<html>
<head>
    <title>Bootstrap Typography</title>
    <link rel="stylesheet" href="css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <h1 class="display-1">
            Bootstrap Typography
        </h1>
        <p class="lead">
            This is a lead paragraph using Bootstrap.
        </p>
        <p class="text-muted">
            This text is muted.
        </p>
        <p class="fw-bold">
            This text is bold.
        </p>
        <p class="text-primary">
            This is primary colored text.
        </p>
    </div>
    <script src="js/bootstrap.bundle.min.js"></script>
</body>
</html>
