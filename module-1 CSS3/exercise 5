<!DOCTYPE html>
<html>
<head>
    <title>Typography Example</title>
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Poppins&display=swap">
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <h1>
        Welcome to City Portal
    </h1>
    <div class="content">
        <h2>
            About Us
        </h2>
        <p class="description">
            This portal provides information about city events and public services.
        </p>
    </div>
</body>
</html










//CSS
body {
    font-family: 'Poppins', sans-serif;
    background-color: #f2f2f2;
    padding: 20px;
}
h1 {
    font-size: 40px;
    font-weight: bold;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: darkblue;
}
h2 {
    font-size: 28px;
    font-style: italic;
    color: darkgreen;
}
.description {
    font-size: 18px;
    line-height: 30px;
    text-align: justify;
    letter-spacing: 1px;
    color: #444444;
}



