<!DOCTYPE html>
<html>
<head>
    <title>Debugging Example</title>
    <style>
        .box{
            width:300px;
            margin:auto;
            border:1px solid black;
            padding:20px;
            text-align:center;
        }
    </style>
</head>
<body>
    <div class="box">
        <h2 id="title">
            Debugging Demo
        </h2>
        <button onclick="showMessage()">
            Click Me
        </button>
        <p id="result"></p>
    </div>
    <script>
        function showMessage(){
            let name = "Ammu";
            console.log("Button Clicked");
            console.log(name);
            document.getElementById("result").innerHTML =
            "Welcome " + name;
        }
    </script>
</body>
</html>
