<!DOCTYPE html>
<html>
<head>
    <title>Event Promo Video</title>
    <style>
        .box{
            width:400px;
            margin:auto;
            text-align:center;
        }
        video{
            width:100%;
            border:2px solid black;
        }
    </style>
</head>
<body>
    <div class="box">
        <h2>Event Promo Video</h2>
        <video controls oncanplay="videoReady()">
            <source src="event.mp4" type="video/mp4">
        </video>
        <p id="msg"></p>
    </div>
    <script>
        function videoReady(){
            document.getElementById("msg").innerHTML =
            "Video Ready to Play";
        }
    </script>
</body>
</html>
